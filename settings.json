{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(shred *)",
      "Bash(unlink *)"
    ],
    "defaultMode": "bypassPermissions",
    "additionalDirectories": [
      "/Users/harugury/Documents/Obsidian Vault"
    ]
  },
  "model": "opusplan",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/harsh-critic-trigger.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/harsh-critic.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/harsh-critic-learn.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$TOOL_INPUT\" | grep -qE '(rm\\s+-rf|DROP\\s+TABLE|force.push)' && echo 'BLOCK: dangerous command' && exit 1 || exit 0"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/pre-commit-flow-check.sh"
          }
        ]
      }
    ]
  },
  "language": "korean",
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true
}
