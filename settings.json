{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "ask": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(shred *)",
      "Bash(unlink *)"
    ],
    "defaultMode": "bypassPermissions",
    "additionalDirectories": [
      "/Users/mac/Library/Mobile Documents/com~apple~CloudDocs/0.원진업무/1. 진행중/0. 파이썬 공부하기",
      "/private/tmp/gas-check/api2"
    ]
  },
  "model": "opusplan",
  "statusLine": {
    "type": "command",
    "command": "node /Users/mac/.claude/hud/omc-hud.mjs"
  },
  "enabledPlugins": {
    "oh-my-claudecode@omc": true,
    "kkirikkiri@gptaku-plugins": true,
    "telegram@claude-plugins-official": false,
    "git-teacher@gptaku-plugins": true,
    "memory-bank@memory-bank-dev": true
  },
  "extraKnownMarketplaces": {
    "omc": {
      "source": {
        "source": "git",
        "url": "https://github.com/Yeachan-Heo/oh-my-claudecode.git"
      }
    },
    "memory-bank": {
      "source": {
        "source": "github",
        "repo": "jung-wan-kim/memory-bank"
      }
    },
    "gptaku-plugins": {
      "source": {
        "source": "git",
        "url": "https://github.com/fivetaku/gptaku_plugins.git"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "memory-bank-dev": {
      "source": {
        "source": "git",
        "url": "https://github.com/jung-wan-kim/memory-bank.git"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "mcpServers": {
    "monday-apps-mcp": {
      "command": "npx",
      "args": [
        "@mondaydotcomorg/monday-api-mcp",
        "-t",
        "eyJhbGciOiJIUzI1NiJ9.eyJ0aWQiOjQ1MTIxMDg2MSwiYWFpIjoxMSwidWlkIjoyODM5NjY2NiwiaWFkIjoiMjAyNC0xMi0yNFQwOTowMTo1Ny4wMDBaIiwicGVyIjoibWU6d3JpdGUiLCJhY3RpZCI6MTExNjU5NTcsInJnbiI6InVzZTEifQ.l0uAa7SJiOQL4NCfnw648jaLcLiqMLr2YcpcJpSn6jQ",
        "--mode",
        "apps"
      ]
    }
  }
}
