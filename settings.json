{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "BASH_MAX_OUTPUT_LENGTH": "20000"
  },
  "includeGitInstructions": false,
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(shred *)",
      "Bash(unlink *)"
    ],
    "defaultMode": "bypassPermissions",
    "additionalDirectories": [
      "/Users/harugury/Documents/Obsidian Vault"
    ]
  },
  "model": "haiku",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/harsh-critic-trigger.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/context-enrichment.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/memory-inject.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/harsh-critic.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/harsh-critic-learn.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/memory-learn.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$TOOL_INPUT\" | grep -qE '(rm\\s+-rf|DROP\\s+TABLE|force.push)' && echo 'BLOCK: dangerous command' && exit 1 || exit 0"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/pre-commit-flow-check.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/auto-validate.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/codex-review-reminder.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/post_bash_git_commit.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/fix-commit-learner.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(*spigen_build.py*)",
        "hooks": [
          {
            "type": "agent",
            "prompt": "방금 spigen-slides로 PPT를 생성했습니다. 페르소나 검수 V5.7 default ON 룰에 따라 즉시 진행하세요.\n\n검수 대상: 직전 Bash stdout의 https://docs.google.com/presentation/d/* URL (또는 build_*.py 출력에 [light]/[dark] NEW/UPDATE 표기된 URL).\n\n검수 기준: ~/.claude/skills/spigen-slides/SKILL.md '페르소나 검수' 섹션 + spigen_subagent_prompts.md (영역 매트릭스 — 기획자/디자이너/청중 각자 영역만).\n\n자동 강제 룰(컬러·좌표·폰트 위계·콘텐츠 영역·표지 2줄 등)은 빌더 코드가 이미 처리. 페르소나는 코드가 못 잡는 텍스트·메시지·카테고리 라벨링·청중 이해도만 검수.\n\n룰: 1회 호출 + 1회 통합 수정 + 종료 (반복 호출 금지). 충돌 시 사용자 1회 문의."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node /Users/harugury/.claude/claude-dashboard/dist/index.js"
  },
  "enabledPlugins": {
    "oh-my-claudecode@omc": true,
    "kkirikkiri@gptaku-plugins": true,
    "nopal@gptaku-plugins": true,
    "telegram@claude-plugins-official": false,
    "git-teacher@gptaku-plugins": true,
    "memory-bank@memory-bank-dev": false,
    "superpowers@claude-plugins-official": true,
    "agent-skills@addy-agent-skills": true,
    "insane-search@insane-search": true,
    "show-me-the-prd@gptaku-plugins": true,
    "skillers-suda@gptaku-plugins": true
  },
  "extraKnownMarketplaces": {
    "omc": {
      "source": {
        "source": "git",
        "url": "https://github.com/Yeachan-Heo/oh-my-claudecode.git"
      }
    },
    "memory-bank": {
      "source": {
        "source": "github",
        "repo": "jung-wan-kim/memory-bank"
      }
    },
    "gptaku-plugins": {
      "source": {
        "source": "git",
        "url": "https://github.com/fivetaku/gptaku_plugins.git"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "memory-bank-dev": {
      "source": {
        "source": "git",
        "url": "https://github.com/jung-wan-kim/memory-bank.git"
      }
    },
    "addy-agent-skills": {
      "source": {
        "source": "github",
        "repo": "addyosmani/agent-skills"
      }
    },
    "insane-search": {
      "source": {
        "source": "github",
        "repo": "fivetaku/insane-search"
      }
    }
  },
  "language": "korean",
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "theme": "light",
  "mcpServers": {
    "monday-apps-mcp": {
      "command": "npx",
      "args": [
        "@mondaydotcomorg/monday-api-mcp",
        "-t",
        "eyJhbGciOiJIUzI1NiJ9.eyJ0aWQiOjQ1MTIxMDg2MSwiYWFpIjoxMSwidWlkIjoyODM5NjY2NiwiaWFkIjoiMjAyNC0xMi0yNFQwOTowMTo1Ny4wMDBaIiwicGVyIjoibWU6d3JpdGUiLCJhY3RpZCI6MTExNjU5NTcsInJnbiI6InVzZTEifQ.l0uAa7SJiOQL4NCfnw648jaLcLiqMLr2YcpcJpSn6jQ",
        "--mode",
        "apps"
      ]
    }
  }
}
